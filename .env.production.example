# Production env — à copier en .env.production sur le VPS et compléter avec les vraies valeurs.
# NE PAS COMMITTER .env.production (juste cet exemple).

# ─── Server ───
NODE_ENV=production
PORT=5003

# MongoDB sur le host, accessible via host.docker.internal depuis le conteneur server
# Crée d'abord l'user "roulade" avec le password de ton choix (cf. scripts/setup-vps.md)
MONGODB_URI=mongodb://roulade:CHANGE_ME_STRONG_PASSWORD@host.docker.internal:27017/roulade-marseillaise?authSource=admin

# JWT — génère un secret aléatoire fort, par exemple : openssl rand -hex 64
JWT_SECRET=CHANGE_ME_RANDOM_HEX_64
JWT_EXPIRES_IN=7d

# Cloudinary (mêmes credentials qu'en dev OU projet dédié prod)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe — passer en mode LIVE (pas test) une fois en prod
# - Récupérer la clé secrète live dans le dashboard
# - Créer un endpoint webhook https://arka.michaelrichaud.fr/api/payments/webhook
#   et copier sa signing secret ici
# - Créer 2 prices LIVE (mensuel + annuel) et copier leurs IDs
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx

# URL publique du client — utilisée pour les redirections Stripe et les liens dans les emails
CLIENT_URL=https://arka.michaelrichaud.fr
